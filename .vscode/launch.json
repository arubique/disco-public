    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Two Stages",
            "type": "debugpy",
            "request": "launch",
            "program": "/home/oh/arubinstein17/github/disco-public/scripts/two_stages.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Two Stages V2",
            "type": "debugpy",
            "request": "launch",
            "program": "/home/oh/arubinstein17/github/disco-public/scripts/two_stages_v2.py",
            "console": "integratedTerminal",
            "args": [
                "--source_model_outputs_path",
                "/home/oh/arubinstein17/github/disco-public/data/model_outputs/mmlu/source_outputs.pkl",
                // "/home/oh/arubinstein17/github/disco-public/data/model_outputs/hellaswag/source_outputs.pkl",
                "--target_model_outputs_path",
                "/home/oh/arubinstein17/github/disco-public/data/model_outputs/mmlu/target_outputs.pkl"
                // "/home/oh/arubinstein17/github/disco-public/data/model_outputs/hellaswag/target_outputs.pkl"
            ]
        },
        {
            "name": "Run Experiment (MMLU Fields PDS)",
            "type": "debugpy",
            "request": "launch",
            "program": "run_experiment.py",
            "console": "integratedTerminal",
            "args": [
                "--bench",
                "mmlu_fields",
                "--device",
                "cuda",
                "--disagreement_type",
                "pds",
                "--estimators",
                "best",
                "--filename_suffix",
                "_disagreement_best_47",
                "--iterations",
                "5",
                "--num_workers",
                "4",
                "--pca",
                "256",
                "--sampling_names",
                "random,high-disagreement,low-disagreement,low-disagreement@2,high-disagreement@2,low-disagreement@10,high-disagreement@10,low-disagreement@100,high-disagreement@100,high-disagreement+nonstratified,low-disagreement+nonstratified,low-disagreement@2+nonstratified,high-disagreement@2+nonstratified,low-disagreement@10+nonstratified,high-disagreement@10+nonstratified,low-disagreement@100+nonstratified,high-disagreement@100+nonstratified",
                "--split",
                "iid",
                "--skip_irt",
                "--make_results_table"
            ],
        },
        {
            "name": "Extract Model Outputs",
            "type": "debugpy",
            "request": "launch",
            "program": "./scripts/extract_model_outputs_from_raw_data.py",
            "console": "integratedTerminal",
        },
        {
            "name": "Plot Tables",
            "type": "debugpy",
            "request": "launch",
            "program": "./scripts/plot_tables.py",
            "console": "integratedTerminal",
            "args": [
                "--source_config_path",
                "./configs/result_paths/pds_results_suffixes.json"
            ]
        },
        {
            "name": "Download Model Outputs",
            "type": "debugpy",
            "request": "launch",
            "program": "./scripts/download_model_outputs.py",
            "console": "integratedTerminal",
        },
        {
            "name": "Download Leaderboard",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/download_leaderboard.py",
            "args": [
                "--lb_type",
                // "mmlu_fields",
                "openllm_leaderboard",
                "--lb_savepath",
                "None",
                "--save_only_once"
            ],
            "console": "integratedTerminal"
        }
    ]
}
